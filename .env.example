# hermes gateway LLM 설정 (agent/skills/hermes_api.py)
#
# 이 파일을 .env 로 복사한 뒤 실제 값을 채우세요. .env 는 git 에 올라가지 않습니다.
#   cp .env.example .env
#
# HERMES_API_KEY 가 비어 있으면 hermes 질의 스킬이 비활성화되고,
# 기존 에코 폴백("인지된 음성은 ... 입니다")이 동작합니다.
# hermes 를 쓰지 않는 개발환경(dev)에서는 .env 를 만들지 않으면 됩니다.

# hermes gateway 주소 (기본값: http://127.0.0.1:8642/v1)
HERMES_BASE_URL=http://127.0.0.1:8642/v1

# API 키. hermes 는 인증을 요구하지 않지만 OpenAI SDK 가 필수로 요구한다.
# 이 값이 있어야 스킬이 활성화되므로 더미 값이라도 채워야 한다.
HERMES_API_KEY=

# 모델 이름 (기본값: qwen3:8b)
HERMES_MODEL=qwen3:8b

# 응답 대기 제한 시간(초) (기본값: 30)
HERMES_TIMEOUT=30


# ==========================================
# 오디오 장치 선택 (agent/config.py)
# ==========================================
# USB 장치의 PyAudio 인덱스는 재연결/부팅 순서에 따라 바뀌므로 인덱스 대신
# 장치 "이름"으로 찾는다. 아래 값은 이름의 부분일치 패턴(대소문자 무시)이며,
# 비워두면 ENVIRONMENTS 프리셋의 기본 패턴(prod = "USB")을 사용한다.
#
# 실제 장치 이름 확인:
#   python main_agent.py --list-devices
# 예: AUDIO_INPUT_NAME=USB PnP Sound Device

AUDIO_INPUT_NAME=
AUDIO_OUTPUT_NAME=
